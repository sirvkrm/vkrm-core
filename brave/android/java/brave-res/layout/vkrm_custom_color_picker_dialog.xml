<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="8dp"
    android:paddingEnd="20dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/vkrm_color_picker_instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/vkrm_custom_color_instruction" />

    <org.chromium.chrome.browser.settings.VkrmColorWheelView
        android:id="@+id/vkrm_color_wheel"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:id="@+id/vkrm_color_preview"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/vkrm_color_preview_circle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/vkrm_custom_color_selected" />

        <TextView
            android:id="@+id/vkrm_color_hex_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="monospace"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
